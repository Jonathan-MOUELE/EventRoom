{% extends 'base.html.twig' %}

{% block title %}
    {% if mode == 'index' %}Liste des {{ entity_name_plural }}
    {% elseif mode == 'show' %}{{ entity_label }} #{{ item.id }}
    {% elseif mode == 'new' %}Nouveau {{ entity_label }}
    {% elseif mode == 'edit' %}Modifier {{ entity_label }}
    {% endif %}
{% endblock %}

{% block body %}
{# =====================================================================
   IMPORTANT : entity_name_plural DOIT être défini ici (dans block body)
   Pour que Twig puisse l'utiliser dans tout ce bloc.
   ===================================================================== #}
{% set entity_name_plural = entity_name_plural|default(entity_label ~ 's') %}

{# ===== FIL D'ARIANE ===== #}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb bg-transparent p-0 mb-0">
        <li class="breadcrumb-item">
            <a href="{{ path('app_home') }}" class="text-decoration-none">
                <i class="fa-solid fa-house"></i>
            </a>
        </li>
        {% if mode != 'index' %}
            <li class="breadcrumb-item">
                <a href="{{ path(route_prefix ~ 'index') }}" class="text-decoration-none">{{ entity_name_plural }}</a>
            </li>
        {% endif %}
        <li class="breadcrumb-item active" aria-current="page">
            {% if mode == 'index' %}{{ entity_name_plural }}
            {% elseif mode == 'new' %}Nouveau
            {% elseif mode == 'edit' %}Modifier #{{ item.id }}
            {% else %}{{ item.id }}
            {% endif %}
        </li>
    </ol>
</nav>

{# ===== TITRE + BOUTON AJOUTER ===== #}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold m-0 h3">
        {% if mode == 'index' %}
            <i class="fa-solid fa-list-ul me-2 text-primary"></i>{{ entity_name_plural }}
        {% elseif mode == 'show' %}
            <i class="fa-solid fa-circle-info me-2 text-primary"></i>Détails : {{ item }}
        {% elseif mode == 'new' %}
            <i class="fa-solid fa-circle-plus me-2 text-success"></i>Créer un(e) {{ entity_label }}
        {% elseif mode == 'edit' %}
            <i class="fa-solid fa-pen-to-square me-2 text-warning"></i>Modifier : {{ item }}
        {% endif %}
    </h1>
    {% if mode == 'index' and (entity_label != 'Salle' or is_granted('ROLE_ADMIN')) %}
        <a href="{{ path(route_prefix ~ 'create') }}" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="fa-solid fa-plus me-2"></i>Ajouter
        </a>
    {% endif %}
</div>

{# ===== CARD PRINCIPALE ===== #}
<div class="card border-0 shadow-sm overflow-hidden">

    {# ---- MODE : LISTE ---- #}
    {% if mode == 'index' %}
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        {% for header in headers %}
                            <th class="px-4 py-3 text-uppercase text-muted fw-semibold small">{{ header }}</th>
                        {% endfor %}
                        <th class="px-4 py-3 text-end text-uppercase text-muted fw-semibold small">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for record in items %}
                        <tr>
                            {% for field in fields %}
                                <td class="px-4 py-3">
                                    {% set val = attribute(record, 'get' ~ field|capitalize) is defined
                                        ? attribute(record, 'get' ~ field|capitalize)
                                        : attribute(record, field) %}
                                    {% if val is iterable %}
                                        {{ val|join(', ') }}
                                    {% elseif val is not null and val.timestamp is defined %}
                                        <i class="fa-regular fa-calendar me-1 text-muted"></i>
                                        {{ val|date('d/m/Y') }}
                                    {% elseif 'image' in field|lower or 'img' in field|lower %}
                                        {% if val %}
                                            <img src="{{ val }}" class="rounded shadow-sm" style="width: 80px; height: 50px; object-fit: cover;" onerror="this.src='https://placehold.co/80x50?text=No+Img'">
                                        {% else %}
                                            <span class="badge bg-light text-muted">N/A</span>
                                        {% endif %}
                                    {% elseif field == 'description' %}
                                        <span title="{{ val }}">{{ val|length > 30 ? val|slice(0, 30) ~ '...' : val }}</span>
                                    {% else %}
                                        {{ val }}
                                    {% endif %}
                                </td>
                            {% endfor %}
                            <td class="px-4 py-3 text-end">
                                <a href="{{ path(route_prefix ~ 'show', {'id': record.id}) }}"
                                   class="btn btn-sm btn-outline-primary me-1" title="Voir">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                {% if entity_label != 'Salle' or is_granted('ROLE_ADMIN') %}
                                <a href="{{ path(route_prefix ~ 'update', {'id': record.id}) }}"
                                   class="btn btn-sm btn-outline-warning" title="Modifier">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="{{ headers|length + 1 }}" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-folder-open fa-2x d-block mb-2 opacity-25"></i>
                                Aucun enregistrement pour le moment.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

    {# ---- MODE : DÉTAIL (SHOW) ---- #}
    {% elseif mode == 'show' %}
        <div class="card-body p-4">
            <div class="row g-4">
                {% for field, label in show_fields %}
                    <div class="col-sm-6">
                        <p class="text-muted small text-uppercase fw-bold mb-1">{{ label }}</p>
                        <div class="fs-6 fw-semibold">
                            {% set val = attribute(item, 'get' ~ field|capitalize) is defined
                                ? attribute(item, 'get' ~ field|capitalize)
                                : attribute(item, field) %}
                            {% if val is iterable %}
                                <span class="badge bg-primary">{{ val|join(', ') }}</span>
                            {% elseif val is not null and val.timestamp is defined %}
                                <i class="fa-solid fa-calendar-day me-1 text-primary"></i>
                                {{ val|date('d/m/Y à H:i') }}
                            {% elseif 'image' in field|lower or 'img' in field|lower %}
                                {% if val %}
                                    <div class="mt-2">
                                        <img src="{{ val }}" class="img-fluid rounded shadow-sm border" style="max-height: 250px;" onerror="this.style.display='none'">
                                    </div>
                                {% else %}
                                    <span class="text-muted fst-italic">Pas d'image</span>
                                {% endif %}
                            {% elseif val is null or val == '' %}
                                <span class="text-muted fst-italic">Non renseigné</span>
                            {% else %}
                                {{ val|nl2br }}
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>

            {# Liste des réservations pour une salle #}
            {% if entity_label == 'Salle' and item.reservations is defined %}
                <div class="mt-5 pt-4 border-top">
                    <h3 class="h5 fw-bold mb-3"><i class="fa-solid fa-clock-rotate-left me-2 text-primary"></i>Planning des réservations</h3>
                    {% if item.reservations|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Responsable</th>
                                        <th>Début</th>
                                        <th>Fin</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for resa in item.reservations %}
                                        <tr>
                                            <td>{{ resa.utilisateur }}</td>
                                            <td>{{ resa.dateDebut|date('d/m/Y H:i') }}</td>
                                            <td>{{ resa.dateFin|date('d/m/Y H:i') }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <p class="text-muted small fst-italic">Aucune réservation pour le moment pour cette salle.</p>
                    {% endif %}
                </div>
            {% endif %}
        </div>

    {# ---- MODE : FORMULAIRE (NEW / EDIT) ---- #}
    {% elseif mode in ['new', 'edit'] %}
        <div class="card-body p-4">
            {{ form_start(form) }}
                <div class="row g-4">
                    {% for child in form %}
                        {% if child.vars.name != '_token' %}
                            <div class="col-md-6">
                                {{ form_label(child, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                                {{ form_widget(child, {'attr': {'class': 'form-control shadow-sm'}}) }}
                                {% if form_errors(child) %}
                                    <div class="text-danger small mt-1">
                                        <i class="fa-solid fa-circle-exclamation me-1"></i>
                                        {{ form_errors(child) }}
                                    </div>
                                {% endif %}
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
                <div class="mt-5 pt-4 border-top d-flex justify-content-end gap-2">
                    <a href="{{ path(route_prefix ~ 'index') }}" class="btn btn-light rounded-pill px-4">
                        <i class="fa-solid fa-xmark me-1"></i>Annuler
                    </a>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 shadow-sm">
                        <i class="fa-solid fa-floppy-disk me-2"></i>
                        {{ mode == 'new' ? 'Créer maintenant' : 'Enregistrer les modifications' }}
                    </button>
                </div>
            {{ form_end(form) }}
        </div>
    {% endif %}

    {# ---- FOOTER DES ACTIONS (show + edit) ---- #}
    {% if mode in ['show', 'edit'] %}
        <div class="card-footer bg-light p-3 d-flex justify-content-between align-items-center">
            <div class="d-flex gap-2">
                {% if mode == 'show' and (entity_label != 'Salle' or is_granted('ROLE_ADMIN')) %}
                    <a href="{{ path(route_prefix ~ 'update', {'id': item.id}) }}"
                       class="btn btn-warning rounded-pill px-4">
                        <i class="fa-solid fa-pen-to-square me-1"></i>Modifier
                    </a>
                {% endif %}
                <a href="{{ path(route_prefix ~ 'index') }}" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="fa-solid fa-arrow-left me-1"></i>Retour
                </a>
            </div>
            {% if entity_label != 'Salle' or is_granted('ROLE_ADMIN') %}
            <form method="post"
                  action="{{ path(route_prefix ~ 'delete', {'id': item.id}) }}"
                  onsubmit="return confirm('Supprimer définitivement cet enregistrement ?');"
                  class="m-0">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                <button type="submit" class="btn btn-link text-danger text-decoration-none p-0">
                    <i class="fa-solid fa-trash-can me-1"></i>Supprimer
                </button>
            </form>
            {% endif %}
        </div>
    {% endif %}

</div>{# /card #}
{% endblock %}
