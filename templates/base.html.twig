<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}EventRoom{% endblock %} — EventRoom</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <!-- Bootstrap 5.3 CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <!-- Google Fonts: Inter -->
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
        <!-- FontAwesome 6.4 -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

        <style>
            :root {
                --bs-font-sans-serif: 'Inter', sans-serif;
            }
            body {
                font-family: var(--bs-font-sans-serif);
                background-color: #f0f2f5;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }
            .navbar {
                background: linear-gradient(135deg, #3E61E0 0%, #2a45b0 100%) !important;
                box-shadow: 0 4px 12px rgba(62,97,224,0.25);
            }
            .navbar-brand { font-size: 1.3rem; letter-spacing: -0.5px; }
            main { flex: 1; }
            footer { background-color: #fff; border-top: 1px solid #eaeaea; }
            .card { border-radius: 1rem !important; }
            .btn-primary { background: #3E61E0; border-color: #3E61E0; }
            .btn-primary:hover { background: #2a45b0; border-color: #2a45b0; }
            .alert { border-radius: 0.75rem; }
            .breadcrumb { font-size: 0.875rem; }
            .table thead th { font-size: 0.75rem; letter-spacing: 0.08em; }
        </style>
        {% block stylesheets %}{% endblock %}
    </head>

    <body>
        <!-- ===== NAVBAR ===== -->
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">
                    <i class="fa-solid fa-calendar-check me-2"></i>EventRoom
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_salle_index') }}">
                                <i class="fa-solid fa-door-open me-1"></i>Salles
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_reservation_index') }}">
                                <i class="fa-solid fa-clock me-1"></i>Réservations
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        {% if app.user %}
                            <li class="nav-item d-flex align-items-center me-3">
                                <span class="text-white opacity-75 small">
                                    <i class="fa-solid fa-circle-user me-1"></i>
                                    {{ app.user.userIdentifier }}
                                </span>
                            </li>
                            <li class="nav-item">
                                <form method="post" action="{{ path('app_logout') }}" class="m-0">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                                    <button type="submit" class="btn btn-sm btn-outline-light rounded-pill px-3">
                                        <i class="fa-solid fa-right-from-bracket me-1"></i>Déconnexion
                                    </button>
                                </form>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="btn btn-sm btn-outline-light rounded-pill px-3" href="{{ path('app_login') }}">
                                    <i class="fa-solid fa-right-to-bracket me-1"></i>Connexion
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <!-- ===== FLASH MESSAGES ===== -->
        {% if app.flashes|length > 0 %}
        <div class="container mt-3">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show shadow-sm" role="alert">
                        <i class="fa-solid {{ label == 'success' ? 'fa-circle-check' : 'fa-triangle-exclamation' }} me-2"></i>
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
        {% endif %}

        <!-- ===== MAIN CONTENT ===== -->
        <main class="container py-4">
            {% block body %}{% endblock %}
        </main>

        <!-- ===== FOOTER ===== -->
        <footer class="py-3 text-center mt-auto">
            <div class="container">
                <span class="text-muted small">© {{ 'now'|date('Y') }} EventRoom — Tous droits réservés</span>
            </div>
        </footer>

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
